# Turso (libSQL) Edge Database
TURSO_DATABASE_URL=libsql://your-db.turso.io
TURSO_AUTH_TOKEN=your-auth-token-here

# Auth.js (NextAuth v5) Configuration
# Run `openssl rand -hex 32` or `npx auth secret` to generate a secret
AUTH_SECRET=your-auth-secret-here
AUTH_URL=http://localhost:3000

# External AI predictions microservice URL
AI_SERVICE_URL=https://your-ai-service.com/api

# Public application variables
NEXT_PUBLIC_APP_NAME=EduTrack

# Google OAuth Configuration
AUTH_GOOGLE_ID=your-google-client-id
AUTH_GOOGLE_SECRET=your-google-client-secret

